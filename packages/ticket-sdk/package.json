{
  "name": "@xrpl-ticketing/ticket-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "setup:devnet": "node --experimental-strip-types ./scripts/setup_devnet.ts",
    "purchase:primary": "node --experimental-strip-types ./scripts/primary_purchase_flow.ts",
    "audit:primary-policy": "npm run build && node --experimental-strip-types ./scripts/primary_hook_audit.ts",
    "audit:primary-hook": "npm run audit:primary-policy",
    "audit:credential-auth": "npm run build && node --experimental-strip-types ./scripts/credential_auth_audit.ts",
    "audit:permissioned-domain": "npm run build && node --experimental-strip-types ./scripts/permissioned_domain_audit.ts",
    "audit:native-batch": "npm run build && node --experimental-strip-types ./scripts/native_batch_audit.ts"
  },
  "dependencies": {
    "xrpl": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
